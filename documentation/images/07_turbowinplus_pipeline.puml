@startuml
skinparam rectangle {
    BackgroundColor<<Build Stage>> LightBlue
    BackgroundColor<<Artifacts>> LightYellow
    BackgroundColor<<Optional Signing>> LightGray
}

title CI Pipeline for TurboWinPlus

:Code change pushed to repository;

partition "Build Stage" <<Build Stage>> {
    fork
        :jar;
        note right
            On Linux (amd64):
            - Install build dependencies
            - Run Gradle build
        end note
        -> turbowin-4.x.jar;
    fork again
        :test;
        note right
            On Linux (amd64):
            - Install testing dependencies
            - Set up virtual display
            - Run tests with screen capture
        end note
        -> screen_capture.webm;
    fork again
        :deb;
        note right
            On Linux (amd64):
            - Install build dependencies
            - Build and package for Linux amd64
        end note
        -> turbowinplus_4.x-1_amd64.deb;
    fork again
        :rpm;
        note right
            On Linux (amd64):
            - Install build dependencies
            - Build and package for Linux amd64
        end note
        -> turbowinplus-4.x-1.x86_64.rpm;
    fork again
        :exe;
        note right
            On Windows Server 2022 (64-bit):
            - Download JDK (64-bit) and WiX
            - Build and package for Windows x64
        end note
        -> TurboWinPlus-4.x_64-bit.exe;
    end fork
}

partition "Artifacts" <<Artifacts>> {
    :Collect Artifacts;
    note right
        Generated artifacts:
        - Optional: turbowin-4.x.jar
        - screen_capture.webm
        - turbowinplus_4.x-1_amd64.deb
        - turbowinplus-4.x-1.x86_64.rpm
        - TurboWinPlus-4.x_64-bit.exe
    end note
}

partition "Optional Signing" <<Optional Signing>> {
    if (Sign Installers and Packages?) then (Yes)
        :Sign Installers and Packages;
        note right
            - Sign Windows executable
            - Sign DEB package
            - Sign RPM package
        end note
        :Signed Artifacts;
        note right
            Signed artifacts:
            - turbowinplus_4.x-1_amd64.deb
            - turbowinplus-4.x-1.x86_64.rpm
            - TurboWinPlus-4.x_64-bit.exe
        end note
    else (No)
        :Skip Signing;
    endif
}

:Release of packages;
@enduml
